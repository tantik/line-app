# ============================================================
# LINE Mini App / Salon Booking
# Example environment variables
#
# IMPORTANT:
# - Do NOT commit real secrets.
# - Put real values only in Vercel Environment Variables.
# - If a secret was committed to GitHub, rotate/reissue it immediately.
# ============================================================

# Supabase public frontend config
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Supabase backend/server-only key
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_SERVER_ONLY

# LINE Messaging API
LINE_CHANNEL_ID=YOUR_LINE_CHANNEL_ID
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN

# Cron protection
CRON_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# App URLs
APP_BASE_URL=https://YOUR_DOMAIN.vercel.app
LINE_WEBHOOK_URL=https://YOUR_DOMAIN.vercel.app/api/line-webhook

# Runtime mode
PUBLIC_DEMO_MODE=false
ADMIN_DEMO_MODE=false
DEFAULT_TIMEZONE=Asia/Tokyo
SALON_SLUG=your-salon-slug